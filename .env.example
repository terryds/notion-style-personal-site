# --- Convex ---
# Set automatically by `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# --- Clerk ---
# https://dashboard.clerk.com -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Set this one in the Convex dashboard (Settings -> Environment Variables),
# NOT in this file. It's the Issuer URL of your Clerk JWT template named "convex".
# CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# --- Cloudflare R2 (image uploads) ---
# https://dash.cloudflare.com -> R2 -> Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Public base URL the bucket is served from.
# Enable "Public Development URL" on the bucket (pub-xxxx.r2.dev) or attach a custom domain.
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# --- Public site URL ---
# Canonical base for sitemap.xml, robots.txt, Open Graph and canonical tags.
# Your production subdomain (e.g. https://notes.yoursite.com); localhost in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Site owner ---
# The single account allowed to edit. Server-side only (never NEXT_PUBLIC).
# Set the SAME value here (for the upload route) AND in the Convex deployment env
# (for write mutations): `npx convex env set OWNER_EMAIL you@example.com`.
OWNER_EMAIL=you@example.com
